---
---
<header class="border-b border-[var(--color-line)]">
  <div class="mx-auto max-w-3xl px-6 py-5 flex items-center justify-between">
    <a href="/" class="group flex items-baseline gap-2">
      <span
        class="text-2xl font-semibold tracking-tight"
        style="font-family: var(--font-display);"
      >Fiorverso</span>
      <span class="text-xs uppercase tracking-[0.2em] text-[var(--color-ink-faint)]">Journal</span>
    </a>
    <nav class="flex items-center gap-6 text-sm font-medium">
      <a href="/" class="hover:text-[var(--color-accent)] transition-colors">Articles</a>
      <a
        href="https://fiorverso.com"
        class="rounded-full bg-[var(--color-ink)] px-4 py-2 text-[var(--color-paper)] hover:bg-[var(--color-accent)] transition-colors"
      >Work with us</a>
    </nav>
  </div>
</header>
