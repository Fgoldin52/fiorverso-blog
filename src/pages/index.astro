---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title="Fiorverso Journal — Web design notes for Baltimore businesses"
  description="Practical notes on websites that win customers: design psychology, conversion, and what actually works for small businesses in Baltimore."
>
  <Header />

  <main class="mx-auto max-w-3xl px-6">
    <!-- Hero -->
    <section class="py-16 sm:py-20 rise">
      <p class="text-sm uppercase tracking-[0.2em] text-[var(--color-accent)] font-semibold">
        The Fiorverso Journal
      </p>
      <h1
        class="mt-4 text-4xl sm:text-5xl font-semibold leading-[1.05] tracking-tight"
        style="font-family: var(--font-display);"
      >
        Why some websites win customers — and most don't.
      </h1>
      <p class="mt-5 text-lg text-[var(--color-ink-soft)] max-w-xl">
        Short, practical reads on design psychology and conversion, written for
        Baltimore small-business owners who want their site to actually pull its weight.
      </p>
    </section>

    <!-- Post list -->
    <section class="pb-10">
      <ul class="divide-y divide-[var(--color-line)]">
        {posts.map((post, i) => (
          <li class="rise" style={`animation-delay: ${0.05 * (i + 1)}s`}>
            <a href={`/blog/${post.id}/`} class="group block py-8">
              <div class="flex flex-wrap items-center gap-3 text-xs">
                {post.data.industry && (
                  <span class="rounded-full bg-[var(--color-paper-deep)] px-3 py-1 font-medium text-[var(--color-ink-soft)] capitalize">
                    {post.data.industry}
                  </span>
                )}
                <span class="uppercase tracking-wider text-[var(--color-ink-faint)]">
                  {fmt(post.data.pubDate)}
                </span>
              </div>
              <h2
                class="mt-3 text-2xl font-semibold leading-snug group-hover:text-[var(--color-accent)] transition-colors"
                style="font-family: var(--font-display);"
              >
                {post.data.title}
              </h2>
              <p class="mt-2 text-[var(--color-ink-soft)]">{post.data.description}</p>
              <span class="mt-3 inline-block text-sm font-medium text-[var(--color-accent-deep)]">
                Read →
              </span>
            </a>
          </li>
        ))}
      </ul>

      {posts.length === 0 && (
        <p class="py-20 text-center text-[var(--color-ink-faint)]">
          No posts yet. Your first one is on the way.
        </p>
      )}
    </section>
  </main>

  <Footer />
</BaseLayout>
